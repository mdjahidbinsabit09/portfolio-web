# Portfolio Environment Variables Template
# Copy this file to .env.local and fill in your actual credentials

# ============ APP SETTINGS ============
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM=GTM-XXXXXXX

# ============ CONTACT FORM ============
# Telegram Bot (for contact notifications)
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHijklmnopqrstuvwxyzABCDEFGH
TELEGRAM_CHAT_ID=987654321

# Gmail (optional - for email notifications)
EMAIL_ADDRESS=your_email@gmail.com
GMAIL_PASSKEY=your_16_char_app_password

# ============ ADMIN PANEL DATABASE ============
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio

# Admin authentication
ADMIN_PASSWORD=your_secure_password_here
JWT_SECRET=generate_a_random_256_character_string_here

# ============ IMAGE UPLOADS ============
# Cloudinary credentials for image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============ OPTIONAL ============
# reCAPTCHA (optional - for contact form protection)
NEXT_PUBLIC_RECAPTCHA_SECRET_KEY=your_recaptcha_key
